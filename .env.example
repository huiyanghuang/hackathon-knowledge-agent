# Google Gemini API Key（必填）
# 申请地址：https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 用于知识抽取、跨教材对齐复核、RAG 生成、对话
LLM_MODEL=gemini-3.1-flash-lite

# 向量索引持久化目录（numpy .npz + metadata.json）
CHROMA_PATH=./data/chroma

# 上传教材的存放目录
UPLOAD_PATH=./data/textbooks

# 整合后字数上限相对原始字数的比例
COMPRESSION_RATIO=0.30

# 跨教材对齐阈值：≥ HIGH 直接合并；LOW–HIGH 之间走 LLM 复核
ALIGN_THRESHOLD_HIGH=0.88
ALIGN_THRESHOLD_LOW=0.70

# Vultr 部署服务器（可选，仅本地运维使用，部署到服务器后不需要）
# VULTR_HOST=
# VULTR_USER=root
# VULTR_PASS=
